generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String

  folders Folder[]
  books   Book[]
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  books Book[]
}

model Book {
  id          String   @id @default(uuid())
  title       String?
  author      String?
  description String?
  image       String?
  createdAt   DateTime @default(now())

  folders Folder[]
  users    User[]
}
